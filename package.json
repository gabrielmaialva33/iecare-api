{
  "name": "care-ie-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ace serve --watch",
    "build": "node ace build --production",
    "start": "node server.js",
    "lint": "eslint . --ext=.ts",
    "format": "prettier --write .",
    "db:reset": "node ace migration:rollback && node ace migration:run && node ace db:seed",
    "db:server": "node ace migration:run && node ace db:seed && node server.js",
    "start:prod": "node ./build/server.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^5.3.0",
    "adonis-preset-ts": "^2.1.0",
    "eslint": "^8.9.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-adonis": "^2.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "prettier": "^2.5.1",
    "typescript": "~4.5",
    "youch": "^3.1.0",
    "youch-terminal": "^2.1.2"
  },
  "dependencies": {
    "@adonisjs/auth": "^8.0.10",
    "@adonisjs/core": "^5.4.0",
    "@adonisjs/lucid": "^16.3.2",
    "@adonisjs/redis": "^7.1.0",
    "@adonisjs/repl": "^3.1.0",
    "luxon": "^2.3.0",
    "pg": "^8.7.3",
    "pino-pretty": "^7.5.1",
    "pretty-list-routes": "^0.0.5",
    "proxy-addr": "^2.0.7",
    "reflect-metadata": "^0.1.13",
    "source-map-support": "^0.5.21"
  }
}
